.admin-page {
  min-height: 100vh;
  padding: 24rpx 20rpx 36rpx;
  box-sizing: border-box;
  background: #f1f5f9;
}

.top-nav {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.nav-btn {
  min-height: 64rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid #dbe8f8;
  background: #ffffff;
  color: #315170;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}

.manage-card {
  border-radius: 26rpx;
  border: 2rpx solid #d8e3f0;
  background: #ffffff;
  padding: 20rpx;
}

.card-title {
  color: #1f2d3d;
  font-size: 34rpx;
  font-weight: 700;
}

.filter-row {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.search-input {
  flex: 1;
  height: 70rpx;
  border-radius: 14rpx;
  border: 2rpx solid #dce4ef;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.search-btn {
  min-width: 100rpx;
  height: 70rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #14b8a6, #06b6d4);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.loading-tip,
.empty-tip {
  min-height: 160rpx;
  color: #6f8297;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.table-wrap {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.table-row {
  border-radius: 20rpx;
  border: 2rpx solid #e3ebf5;
  background: #f8fafc;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #334155;
  font-size: 26rpx;
  font-weight: 700;
}

.score {
  color: #14b8a6;
  font-size: 22rpx;
  font-weight: 700;
}

.row-sub {
  color: #64748b;
  font-size: 23rpx;
}

.tag-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  min-height: 42rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(20, 184, 166, 0.14);
  color: #0f766e;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
}

.action-btn {
  margin-top: 2rpx;
  align-self: flex-start;
  min-height: 60rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(64, 158, 255, 0.16);
  color: #2563eb;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
}

.pager {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #64748b;
  font-size: 22rpx;
}

.pager-btn {
  min-height: 58rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid #dce4ef;
  background: #ffffff;
  color: #334155;
  display: inline-flex;
  align-items: center;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 998;
}

.modal-card {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  top: 22%;
  z-index: 999;
  border-radius: 26rpx;
  border: 2rpx solid #dbe4f2;
  background: #ffffff;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.modal-title {
  color: #1f2d3d;
  font-size: 32rpx;
  font-weight: 700;
}

.modal-row {
  color: #4b5f74;
  font-size: 24rpx;
}

.modal-label {
  color: #475569;
  font-size: 24rpx;
  font-weight: 600;
}

.modal-input {
  height: 70rpx;
  border-radius: 14rpx;
  border: 2rpx solid #dce4ef;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.helper-text {
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.4;
}

.modal-actions {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.modal-btn {
  min-height: 66rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}

.modal-btn.ghost {
  border: 2rpx solid #dce4ef;
  color: #475569;
  background: #ffffff;
}

.modal-btn.primary {
  color: #ffffff;
  background: linear-gradient(135deg, #14b8a6, #06b6d4);
}

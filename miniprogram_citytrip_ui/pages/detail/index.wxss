.detail-page {
  min-height: 100vh;
  padding: 28rpx 20rpx 48rpx;
  box-sizing: border-box;
}

.detail-shell {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-card,
.info-card,
.replace-card {
  border-radius: 48rpx;
  border: 2rpx solid rgba(223, 232, 244, 0.95);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(31, 45, 61, 0.06);
}

.hero-card {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.back-btn {
  align-self: flex-start;
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d9e6f7;
  color: #315170;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}

.hero-title {
  color: #1f2d3d;
  font-size: 52rpx;
  font-weight: 800;
}

.hero-copy {
  color: #607185;
  font-size: 25rpx;
  line-height: 1.8;
}

.tag-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  min-height: 46rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(64, 158, 255, 0.12);
  color: #2d79c7;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
}

.tag.light {
  background: rgba(148, 163, 184, 0.14);
  color: #5d6f84;
}

.detail-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.info-card,
.replace-card {
  padding: 24rpx;
}

.eyebrow {
  color: #2d79c7;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.info-item {
  border-radius: 20rpx;
  border: 2rpx solid rgba(220, 230, 242, 0.9);
  background: linear-gradient(180deg, #f9fbff 0%, #f4f8ff 100%);
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #7a8da3;
  font-size: 23rpx;
}

.info-value {
  color: #1f2d3d;
  font-size: 32rpx;
  font-weight: 700;
}

.replace-copy {
  color: #647588;
  font-size: 25rpx;
  line-height: 1.8;
}

.replace-btn {
  margin-top: 16rpx;
  min-height: 76rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.empty-tip {
  min-height: 260rpx;
  border-radius: 36rpx;
  border: 2rpx dashed rgba(195, 210, 228, 0.9);
  color: #6f8297;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

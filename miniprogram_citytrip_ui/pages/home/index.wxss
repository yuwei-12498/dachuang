.home-page {
  background: #f7f8fa;
}

.hero-section {
  padding: 56rpx 24rpx 28rpx;
}

.hero-card {
  border-radius: 40rpx;
  background: linear-gradient(145deg, #ffffff, #f4f9ff);
  border: 2rpx solid rgba(217, 230, 247, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(31, 45, 61, 0.06);
  padding: 48rpx 42rpx;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  min-height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(64, 158, 255, 0.1);
  color: #2d79c7;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1.25;
  color: #1f2d3d;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.text-highlight {
  background: linear-gradient(90deg, #409eff, #66b1ff);
  -webkit-background-clip: text;
  color: transparent;
}

.hero-subtitle {
  margin-top: 24rpx;
  color: #606266;
  font-size: 30rpx;
  line-height: 1.7;
}

.hero-actions {
  margin-top: 34rpx;
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.hero-btn {
  min-height: 86rpx;
  padding: 0 32rpx;
  border-radius: 43rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.hero-btn.primary {
  color: #ffffff;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  box-shadow: 0 10rpx 24rpx rgba(64, 158, 255, 0.3);
}

.hero-btn.ghost {
  color: #303133;
  background: #ffffff;
  border: 2rpx solid #dcdfe6;
}

.hero-stats {
  margin-top: 34rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-item {
  border-radius: 24rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #edf3fb;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stat-num {
  color: #303133;
  font-size: 42rpx;
  font-weight: 700;
}

.stat-label {
  color: #909399;
  font-size: 22rpx;
}

.core-section {
  padding: 24rpx 20rpx 42rpx;
  background: #ffffff;
}

.section-header {
  text-align: center;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.section-title {
  color: #1f2d3d;
  font-size: 52rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #606266;
  font-size: 26rpx;
  line-height: 1.65;
}

.core-layout {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.form-card {
  width: 100%;
  box-sizing: border-box;
  border-radius: 40rpx;
  border: 2rpx solid rgba(228, 231, 237, 0.6);
  box-shadow: 0 18rpx 40rpx rgba(31, 45, 61, 0.06);
  padding: 28rpx 24rpx;
}

.sub-section-title {
  position: relative;
  padding-left: 16rpx;
  margin-bottom: 16rpx;
  color: #475669;
  font-size: 30rpx;
  font-weight: 700;
}

.sub-section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 6rpx;
  width: 6rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: #409eff;
}

.field-title {
  color: #475669;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 10rpx;
}

.field-item {
  min-width: 0;
}

.option-row {
  display: flex;
  gap: 10rpx;
}

.option-row.wrap {
  flex-wrap: wrap;
}

.chip {
  min-height: 62rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  border: 2rpx solid #dcdfe6;
  background: #ffffff;
  color: #586a7f;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.chip.active {
  color: #2d79c7;
  border-color: rgba(64, 158, 255, 0.5);
  background: linear-gradient(135deg, rgba(64, 158, 255, 0.12), rgba(102, 177, 255, 0.2));
}

.picker {
  min-height: 70rpx;
  border-radius: 14rpx;
  border: 2rpx solid #dcdfe6;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  color: #303133;
  font-size: 26rpx;
  background: #ffffff;
}

.divider {
  height: 2rpx;
  margin: 20rpx 0;
  background: linear-gradient(90deg, rgba(64, 158, 255, 0.18), rgba(64, 158, 255, 0.02));
}

.switch-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.switch-item {
  border-radius: 18rpx;
  border: 2rpx solid #e7edf6;
  background: #f9fbff;
  padding: 14rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #4f6278;
  font-size: 24rpx;
}

.login-reminder {
  margin: 18rpx auto 0;
  color: #6c7d90;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.6;
}

.submit-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 84rpx;
  border-radius: 42rpx;
  border: none;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(64, 158, 255, 0.26);
}

.scenario-section,
.feature-section,
.examples-section {
  padding: 64rpx 24rpx;
}

.scenario-section,
.examples-section {
  background: #f7f8fa;
}

.feature-section {
  background: #ffffff;
}

.scenario-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.scenario-card {
  border-radius: 28rpx;
  border: 2rpx solid rgba(228, 231, 237, 0.4);
  background: #ffffff;
  padding: 24rpx 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.icon.blue {
  background: linear-gradient(135deg, #409eff, #3a8ee6);
}

.icon.pink {
  background: linear-gradient(135deg, #ff758c, #ff7eb3);
}

.icon.orange {
  background: linear-gradient(135deg, #f6d365, #fda085);
}

.icon.purple {
  background: linear-gradient(135deg, #a18cd1, #fbc2eb);
}

.card-title {
  color: #303133;
  font-size: 30rpx;
  font-weight: 700;
}

.card-desc {
  color: #606266;
  font-size: 24rpx;
  line-height: 1.65;
}

.feature-card {
  margin-top: 14rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(228, 231, 237, 0.6);
  background: #f7f8fa;
  padding: 24rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.feature-label {
  color: #409eff;
  font-size: 22rpx;
  font-weight: 700;
}

.feature-title {
  color: #1f2d3d;
  font-size: 34rpx;
  font-weight: 700;
}

.feature-desc {
  color: #606266;
  font-size: 25rpx;
  line-height: 1.7;
}

.example-card {
  margin-top: 14rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
}

.cover {
  height: 220rpx;
}

.cover.light {
  background: linear-gradient(120deg, #fdfbfb 0%, #ebedee 100%);
}

.cover.gradient {
  background: linear-gradient(120deg, #e0c3fc 0%, #8ec5fc 100%);
}

.example-body {
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.example-title {
  color: #303133;
  font-size: 30rpx;
  font-weight: 700;
}

.example-desc {
  color: #606266;
  font-size: 24rpx;
  line-height: 1.6;
}

.cta-section {
  background: #1f2d3d;
  color: #ffffff;
  padding: 70rpx 24rpx 30rpx;
  text-align: center;
}

.cta-title {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.35;
}

.cta-subtitle {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #a0aec0;
}

.cta-btn {
  margin: 30rpx auto 0;
  min-height: 92rpx;
  padding: 0 42rpx;
  border-radius: 46rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(64, 158, 255, 0.35);
}

.footer-bar {
  margin-top: 36rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.12);
  color: #8492a6;
  font-size: 22rpx;
}

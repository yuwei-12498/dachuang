.auth-page {
  min-height: 100vh;
  padding: 36rpx 20rpx 50rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(64, 158, 255, 0.12), transparent 34%),
    linear-gradient(180deg, #f6f9fe 0%, #f7f8fa 100%);
}

.auth-shell {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.auth-intro {
  position: relative;
  overflow: hidden;
  border-radius: 40rpx;
  padding: 40rpx 34rpx;
  background: linear-gradient(145deg, #ffffff, #f4f9ff);
  border: 2rpx solid rgba(217, 230, 247, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(31, 45, 61, 0.06);
}

.intro-badge {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(64, 158, 255, 0.1);
  color: #2d79c7;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.intro-title {
  margin: 0;
  display: flex;
  flex-direction: column;
  font-size: 56rpx;
  line-height: 1.2;
  color: #1f2d3d;
  font-weight: 800;
}

.intro-title text {
  color: transparent;
  background: linear-gradient(90deg, #409eff, #66b1ff);
  -webkit-background-clip: text;
}

.intro-desc {
  margin-top: 20rpx;
  color: #5f6f82;
  font-size: 28rpx;
  line-height: 1.7;
}

.intro-points {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.point-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  border-radius: 24rpx;
  border: 2rpx solid rgba(223, 232, 244, 0.9);
  background: rgba(255, 255, 255, 0.84);
  padding: 16rpx 18rpx;
}

.point-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  box-shadow: 0 10rpx 20rpx rgba(64, 158, 255, 0.18);
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.point-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: #647588;
  font-size: 24rpx;
  line-height: 1.6;
}

.point-title {
  color: #1f2d3d;
  font-size: 30rpx;
  font-weight: 700;
}

.auth-card {
  border-radius: 40rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 24rpx 48rpx rgba(31, 45, 61, 0.08);
}

.card-head {
  padding: 16rpx 16rpx 0;
}

.head-kicker {
  display: inline-flex;
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  align-items: center;
  background: #f1f7ff;
  color: #409eff;
  font-size: 22rpx;
  font-weight: 700;
}

.card-title {
  margin-top: 14rpx;
  color: #1f2d3d;
  font-size: 42rpx;
  line-height: 1.4;
  font-weight: 700;
}

.card-sub {
  margin-top: 10rpx;
  color: #738397;
  font-size: 25rpx;
  line-height: 1.6;
}

.tab-row {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  padding: 0 16rpx;
}

.tab-item {
  min-height: 76rpx;
  border-radius: 16rpx;
  border: 2rpx solid #dce2eb;
  background: #ffffff;
  color: #607185;
  font-size: 28rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active {
  border-color: rgba(64, 158, 255, 0.55);
  color: #2d79c7;
  background: linear-gradient(135deg, rgba(64, 158, 255, 0.12), rgba(102, 177, 255, 0.2));
}

.form-body {
  padding: 16rpx;
}

.field-label {
  color: #475669;
  font-size: 26rpx;
  font-weight: 600;
  margin: 12rpx 0 8rpx;
}

.field-input {
  min-height: 76rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(220, 223, 230, 0.8);
  background: #ffffff;
  padding: 0 18rpx;
  font-size: 26rpx;
}

.submit-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 84rpx;
  border: none;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  box-shadow: 0 10rpx 18rpx rgba(64, 158, 255, 0.2);
}

.history-page {
  min-height: 100vh;
  padding: 28rpx 20rpx 48rpx;
  box-sizing: border-box;
}

.history-shell {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-card,
.stat-card,
.history-card {
  border-radius: 48rpx;
  border: 2rpx solid rgba(223, 232, 244, 0.95);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(31, 45, 61, 0.06);
}

.hero-card {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-title {
  color: #1f2d3d;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.35;
}

.hero-copy {
  color: #607185;
  font-size: 25rpx;
  line-height: 1.8;
}

.hero-btn {
  align-self: flex-start;
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  display: inline-flex;
  align-items: center;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}

.stat-card {
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-card text:first-child {
  color: #7a8da3;
  font-size: 24rpx;
}

.stat-value {
  color: #1f2d3d;
  font-size: 42rpx;
  font-weight: 700;
}

.filter-bar {
  display: flex;
  gap: 12rpx;
}

.filter-pill {
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(214, 226, 242, 0.95);
  background: rgba(255, 255, 255, 0.9);
  color: #586a7f;
  font-size: 24rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
}

.filter-pill.active {
  border-color: rgba(64, 158, 255, 0.48);
  background: linear-gradient(135deg, rgba(64, 158, 255, 0.12), rgba(102, 177, 255, 0.18));
  color: #2d79c7;
}

.loading-tip,
.empty-tip {
  min-height: 180rpx;
  border-radius: 32rpx;
  border: 2rpx dashed rgba(195, 210, 228, 0.9);
  color: #6f8297;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20rpx;
  box-sizing: border-box;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.history-card {
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card-top {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-kicker {
  color: #7a8da3;
  font-size: 24rpx;
}

.card-title {
  color: #1f2d3d;
  font-size: 40rpx;
  font-weight: 700;
}

.card-route {
  color: #4f6278;
  font-size: 25rpx;
  line-height: 1.7;
}

.favorite-btn {
  align-self: flex-start;
  min-height: 66rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(214, 226, 242, 0.95);
  background: #ffffff;
  color: #6c7d90;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}

.favorite-btn.active {
  color: #d48806;
  border-color: rgba(230, 162, 60, 0.35);
  background: linear-gradient(135deg, rgba(230, 162, 60, 0.12), rgba(255, 228, 180, 0.2));
}

.favorite-btn.disabled {
  opacity: 0.68;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  min-height: 44rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(64, 158, 255, 0.12);
  color: #2d79c7;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
}

.tag.light {
  background: rgba(148, 163, 184, 0.14);
  color: #5d6f84;
}

.tag.green {
  background: rgba(103, 194, 58, 0.12);
  color: #5b8f2d;
}

.tag.orange {
  background: rgba(230, 162, 60, 0.12);
  color: #ab6f13;
}

.tag.pink {
  background: rgba(245, 108, 108, 0.12);
  color: #c95a5a;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #738397;
  font-size: 24rpx;
}

.actions-row {
  margin-top: 6rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.action-btn {
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d9e6f7;
  background: #ffffff;
  color: #315170;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}

.action-btn.primary {
  border-color: #409eff;
  color: #ffffff;
  background: linear-gradient(135deg, #409eff, #66b1ff);
}

.admin-page {
  min-height: 100vh;
  padding: 24rpx 20rpx 36rpx;
  box-sizing: border-box;
  background: #f1f5f9;
}

.top-nav {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.nav-btn {
  min-height: 64rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid #dbe8f8;
  background: #ffffff;
  color: #315170;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}

.manage-card {
  border-radius: 26rpx;
  border: 2rpx solid #d8e3f0;
  background: #ffffff;
  padding: 20rpx;
}

.card-title {
  color: #1f2d3d;
  font-size: 34rpx;
  font-weight: 700;
}

.filter-row {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.search-input {
  flex: 1;
  height: 70rpx;
  border-radius: 14rpx;
  border: 2rpx solid #dce4ef;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.search-btn {
  min-width: 100rpx;
  height: 70rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #14b8a6, #06b6d4);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.loading-tip,
.empty-tip {
  min-height: 160rpx;
  color: #6f8297;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.table-wrap {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.table-row {
  border-radius: 20rpx;
  border: 2rpx solid #e3ebf5;
  background: #f8fafc;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #334155;
  font-size: 26rpx;
  font-weight: 700;
}

.row-sub {
  color: #64748b;
  font-size: 23rpx;
}

.badge {
  min-height: 42rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #d1fae5;
  color: #047857;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
}

.badge.danger {
  background: #fee2e2;
  color: #b91c1c;
}

.action-row {
  margin-top: 2rpx;
}

.action-btn {
  min-height: 60rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
}

.freeze {
  background: rgba(245, 108, 108, 0.14);
  color: #d23f3f;
}

.unfreeze {
  background: rgba(103, 194, 58, 0.14);
  color: #4c8f20;
}

.pager {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #64748b;
  font-size: 22rpx;
}

.pager-btn {
  min-height: 58rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid #dce4ef;
  background: #ffffff;
  color: #334155;
  display: inline-flex;
  align-items: center;
}

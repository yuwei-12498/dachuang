.result-page {
  min-height: 100vh;
  padding: 28rpx 20rpx 48rpx;
  box-sizing: border-box;
}

.result-shell {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hero-card,
.option-panel,
.stat-card,
.copy-card,
.stop-card,
.map-card {
  border-radius: 48rpx;
  border: 2rpx solid rgba(223, 232, 244, 0.95);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(31, 45, 61, 0.06);
}

.hero-card {
  padding: 28rpx;
}

.hero-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-title {
  color: #1f2d3d;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.35;
}

.hero-copy {
  color: #627386;
  font-size: 26rpx;
  line-height: 1.7;
}

.hero-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.pill {
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(214, 226, 242, 0.95);
  background: #ffffff;
  color: #586a7f;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.pill.warning {
  border-color: rgba(230, 162, 60, 0.35);
  color: #d48806;
  background: linear-gradient(135deg, rgba(230, 162, 60, 0.12), rgba(255, 228, 180, 0.2));
}

.pill.primary {
  border-color: #409eff;
  color: #ffffff;
  background: linear-gradient(135deg, #409eff, #66b1ff);
}

.pill.disabled {
  opacity: 0.68;
}

.option-panel {
  padding: 24rpx;
}

.panel-header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.panel-title {
  color: #1f2d3d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.35;
}

.panel-copy {
  color: #627386;
  font-size: 25rpx;
  line-height: 1.7;
}

.option-counter {
  align-self: flex-start;
  min-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #2d79c7;
  font-size: 24rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(64, 158, 255, 0.12), rgba(102, 177, 255, 0.22));
}

.option-grid,
.stats-grid,
.copy-grid {
  display: grid;
  gap: 14rpx;
}

.option-grid,
.stats-grid,
.copy-grid {
  grid-template-columns: 1fr;
}

.option-card {
  padding: 22rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(223, 232, 244, 0.95);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 255, 0.96));
  box-shadow: 0 18rpx 32rpx rgba(31, 45, 61, 0.05);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.option-card.active {
  border-color: rgba(64, 158, 255, 0.72);
  box-shadow: 0 22rpx 42rpx rgba(64, 158, 255, 0.14);
}

.option-head {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
}

.option-label {
  color: #2d79c7;
  font-size: 24rpx;
  font-weight: 700;
}

.option-sub {
  color: #1f2d3d;
  font-size: 34rpx;
  font-weight: 700;
}

.option-state {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(64, 158, 255, 0.1);
  color: #2d79c7;
  font-size: 22rpx;
  font-weight: 700;
  align-self: flex-start;
}

.option-summary,
.option-copy {
  color: #55687d;
  font-size: 25rpx;
  line-height: 1.7;
}

.option-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #66788c;
  font-size: 23rpx;
}

.option-copy .strong {
  margin-right: 4rpx;
  color: #2f4b68;
  font-weight: 700;
}

.option-copy.muted {
  color: #738498;
}

.stat-card,
.copy-card {
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-card text:first-child {
  color: #7a8da3;
  font-size: 24rpx;
}

.stat-value {
  color: #1f2d3d;
  font-size: 48rpx;
  font-weight: 700;
}

.copy-card text:last-child {
  color: #4f6278;
  font-size: 25rpx;
  line-height: 1.8;
}

.alert-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.alert-chip {
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(245, 182, 93, 0.45);
  background: rgba(255, 247, 230, 0.92);
  color: #9a6a1f;
  font-size: 23rpx;
  display: inline-flex;
  align-items: center;
}

.map-card {
  padding: 24rpx;
}

.map-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.map-title {
  color: #1f2d3d;
  font-size: 42rpx;
  font-weight: 700;
}

.map-copy {
  color: #67788c;
  font-size: 24rpx;
  line-height: 1.7;
}

.map-canvas {
  width: 100%;
  height: 380rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(220, 230, 242, 0.9);
}

.map-empty {
  min-height: 220rpx;
  border-radius: 24rpx;
  border: 2rpx dashed rgba(195, 210, 228, 0.9);
  background: linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
  color: #7a8da3;
  font-size: 24rpx;
  line-height: 1.6;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
  text-align: center;
}

.stop-strip {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.stop-pill {
  min-height: 56rpx;
  padding: 0 16rpx 0 10rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(214, 226, 242, 0.95);
  background: #f7fbff;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.stop-index {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  color: #ffffff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.stop-name {
  color: #425468;
  font-size: 23rpx;
  font-weight: 600;
}

.timeline-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.timeline-time {
  color: #409eff;
  font-size: 25rpx;
  font-weight: 700;
}

.stop-card {
  margin-top: 8rpx;
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.stop-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.stop-kicker {
  color: #7c8da1;
  font-size: 22rpx;
}

.stop-title {
  color: #1f2d3d;
  font-size: 40rpx;
  font-weight: 700;
}

.stop-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  min-height: 46rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(64, 158, 255, 0.12);
  color: #2d79c7;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
}

.tag.light {
  background: rgba(148, 163, 184, 0.14);
  color: #5d6f84;
}

.stop-copy,
.stop-note {
  color: #56697f;
  font-size: 25rpx;
  line-height: 1.7;
}

.stop-note {
  color: #8c6b29;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  color: #738397;
  font-size: 24rpx;
}

.detail-btn {
  align-self: flex-end;
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}

.empty-state {
  min-height: 300rpx;
  border-radius: 36rpx;
  border: 2rpx dashed rgba(200, 214, 232, 0.9);
  color: #6f8297;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20rpx;
  box-sizing: border-box;
}

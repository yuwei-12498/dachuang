<view class="result-page page-shell">
  <view wx:if="{{itinerary}}" class="result-shell">
    <view class="hero-card">
      <view class="hero-main">
        <text class="eyebrow">浣犵殑宸蹭繚瀛樿绋?/text>
        <text class="hero-title">{{heroTitleText}}</text>
        <text class="hero-copy">{{heroDateText}}</text>
        <text wx:if="{{departureText}}" class="hero-location">{{departureText}}</text>
      </view>
      <view class="hero-actions">
        <view class="pill" bindtap="goBack">杩斿洖棣栭〉</view>
        <view class="pill" bindtap="goHistory">鍘嗗彶琛岀▼</view>
        <view class="pill {{itinerary.favorited ? 'warning' : ''}} {{favoriteLoading ? 'disabled' : ''}}" bindtap="handleFavorite">{{favoriteLoading ? (itinerary.favorited ? "鍙栨秷涓?.." : "鏀惰棌涓?..") : (itinerary.favorited ? "鍙栨秷鏀惰棌" : "鏀惰棌琛岀▼")}}</view>
        <view class="pill primary {{replanning ? 'disabled' : ''}}" bindtap="handleReplan">{{replanning ? "閲嶆帓涓?.." : "鎹竴鐗堣矾绾?}}</view>
      </view>
    </view>

    <view wx:if="{{displayOptions.length}}" class="option-panel">
      <view class="panel-header">
        <view>
          <text class="eyebrow">鏂规瀵规瘮</text>
          <text class="panel-title">鍏堟瘮杈冿紝鍐嶅喅瀹氱敤鍝潯璺嚎鍑哄彂</text>
          <text class="panel-copy">姣忎釜鏂规閮界粰鍑烘帹鑽愮悊鐢变笌鍙栬垗璇存槑锛屾柟渚夸綘鏄庣‘涓轰粈涔堥€夊畠銆?/text>
        </view>
        <view class="option-counter">鍊欓€夋柟妗?{{displayOptions.length}}</view>
      </view>

      <view class="option-grid">
        <view
          wx:for="{{displayOptions}}"
          wx:key="optionKey"
          class="option-card {{item.optionKey === activeOptionKey ? 'active' : ''}}"
          data-key="{{item.optionKey}}"
          bindtap="handleSelectOption"
        >
          <view class="option-head">
            <view>
              <text class="option-label">{{item.title}}</text>
              <text class="option-sub">{{item.subtitle}}</text>
            </view>
            <text class="option-state">{{item.stateText}}</text>
          </view>
          <text class="option-summary">{{item.summary}}</text>
          <view class="option-metrics">
            <text>鎬绘椂闀?{{item.durationText}}</text>
            <text>鎬昏姳璐?楼{{item.costText}}</text>
            <text>鐐逛綅 {{item.stopText}}</text>
          </view>
          <text class="option-copy"><text class="strong">鎺ㄨ崘锛?/text>{{item.recommendReason}}</text>
          <text class="option-copy muted"><text class="strong">涓嶄紭鍏堬細</text>{{item.notRecommendReason}}</text>
        </view>
      </view>
    </view>

    <view class="stats-grid">
      <view class="stat-card">
        <text>鎬绘椂闀?/text>
        <text class="stat-value">{{activeDurationText}}</text>
      </view>
      <view class="stat-card">
        <text>棰勮鑺辫垂</text>
        <text class="stat-value">{{activeCostText}}</text>
      </view>
      <view class="stat-card">
        <text>鎺ㄨ崘鐐逛綅</text>
        <text class="stat-value">{{activeStopCount}}</text>
      </view>
    </view>

    <view class="copy-grid">
      <view class="copy-card">
        <text class="eyebrow">涓轰粈涔堟帹鑽愯繖涓?/text>
        <text>{{reasonText}}</text>
      </view>
      <view class="copy-card">
        <text class="eyebrow">涓轰粈涔堜笉浼樺厛閫夊埆鐨?/text>
        <text>{{compareText}}</text>
      </view>
      <view class="copy-card">
        <text class="eyebrow">鎵ц鎻愰啋</text>
        <text>{{itinerary.tips}}</text>
      </view>
    </view>

    <view wx:if="{{activeAlerts.length}}" class="alert-strip">
      <text wx:for="{{activeAlerts}}" wx:key="index" class="alert-chip">{{item}}</text>
    </view>

    <view class="map-card">
      <view class="map-head">
        <view>
          <text class="eyebrow">璺嚎鍦板浘</text>
          <text class="map-title">鎶婅繖鏉¤矾绾挎斁鍒板湴鍥句笂鐪?/text>
          <text class="map-copy">鎸夊綋鍓嶆帹鑽愰『搴忓睍绀虹珯鐐逛綅缃笌杩炵嚎锛屾柟渚夸綘蹇€熷垽鏂『璺▼搴︺€?/text>
        </view>
      </view>
      <map
        wx:if="{{mapData.showMap}}"
        class="map-canvas"
        latitude="{{mapData.latitude}}"
        longitude="{{mapData.longitude}}"
        markers="{{mapData.markers}}"
        polyline="{{mapData.polyline}}"
        show-location="true"
      />
      <view wx:else class="map-empty">褰撳墠璺嚎缂哄皯瓒冲鍧愭爣淇℃伅锛屾殏鏃舵棤娉曠粯鍒跺湴鍥俱€?/view>
      <view class="stop-strip">
        <view wx:for="{{activeNodes}}" wx:key="poiId" class="stop-pill">
          <text class="stop-index">{{index + 1}}</text>
          <text class="stop-name">{{item.poiName}}</text>
        </view>
      </view>
    </view>

    <view class="timeline-wrap">
      <view wx:for="{{activeNodes}}" wx:key="poiId" class="timeline-item">
        <text class="timeline-time">{{item.startTime}} - {{item.endTime}}</text>
        <view class="stop-card">
          <view class="stop-head">
            <view>
              <text class="stop-kicker">绗?{{item.stepOrder}} 绔?/text>
              <text class="stop-title">{{item.poiName}}</text>
            </view>
            <view class="stop-tags">
              <text class="tag">{{item.category}}</text>
              <text class="tag light">{{item.district}}</text>
            </view>
          </view>
          <text class="stop-copy">{{item.sysReason}}</text>
          <text wx:if="{{item.statusNote}}" class="stop-note">{{item.statusNote}}</text>
          <view class="meta-row">
            <text>璺笂锛歿{item.travelText}}</text>
            <text wx:if="{{item.modeText}}">{{item.stepOrder === 1 ? '棣栨鏂瑰紡' : '鏈鏂瑰紡'}}锛歿{item.modeText}}</text>
            <text wx:if="{{item.distanceText}}">璺濈绾︼細{{item.distanceText}}</text>
            <text>鍋滅暀锛歿{item.stayText}}</text>
            <text>鑺辫垂锛歿{item.costText}}</text>
          </view>
          <view class="detail-btn" data-poiid="{{item.poiId}}" bindtap="goToDetail">鏌ョ湅璇︽儏骞舵浛鎹?/view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">鏆傛椂娌℃湁鎵惧埌琛岀▼锛岃鍏堝洖棣栭〉鐢熸垚銆?/view>

  <chat-widget id="chatWidget" showWidget="{{true}}" />
</view>

<view wx:if="{{showWidget}}" class="chat-widget">
  <view wx:if="{{!isOpen}}" class="chat-fab" bindtap="toggleChat">
    <text class="fab-icon">AI</text>
    <text class="fab-text">问问行程助手</text>
  </view>

  <view wx:if="{{isOpen}}" class="chat-panel">
    <view class="chat-header">
      <view class="header-left">
        <text class="header-dot"></text>
        <text class="chat-title">行程灵感助手</text>
      </view>
      <text class="close-icon" bindtap="toggleChat">×</text>
    </view>

    <scroll-view class="chat-body" scroll-y="true" scroll-with-animation="true">
      <view class="msg-container">
        <block wx:for="{{messages}}" wx:key="index">
          <view wx:if="{{item.role === 'assistant'}}" class="msg-row msg-left">
            <view class="avatar bg-blue">AI</view>
            <view class="msg-bubble assistant-bubble">{{item.content}}</view>
          </view>
          <view wx:if="{{item.role === 'user'}}" class="msg-row msg-right">
            <view class="msg-bubble user-bubble">{{item.content}}</view>
            <view class="avatar bg-orange">我</view>
          </view>
        </block>

        <view wx:if="{{loading}}" class="msg-row msg-left">
          <view class="avatar bg-blue">AI</view>
          <view class="msg-bubble assistant-bubble">正在帮你梳理路线...</view>
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{currentTips.length > 0}}" class="quick-tips">
      <text
        wx:for="{{currentTips}}"
        wx:key="index"
        class="tip-tag"
        data-tip="{{item}}"
        bindtap="sendByTip"
      >{{item}}</text>
    </view>

    <view class="chat-footer">
      <input
        class="chat-input"
        placeholder="想问哪里更适合你？我来帮你想路线..."
        value="{{inputVal}}"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="handleSend"
      />
      <view class="send-btn {{(!inputVal || loading) ? 'disabled' : ''}}" bindtap="handleSend">发送</view>
    </view>
  </view>
</view>

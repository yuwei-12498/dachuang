.chat-widget {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.chat-fab {
  height: 108rpx;
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  padding: 0 36rpx;
  background: linear-gradient(135deg, #409eff, #3a8ee6);
  box-shadow: 0 8rpx 32rpx rgba(64, 158, 255, 0.4);
}

.fab-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.fab-text {
  margin-left: 14rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.chat-panel {
  width: 680rpx;
  height: 960rpx;
  border-radius: 32rpx;
  border: 2rpx solid #ebeef5;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 20rpx 70rpx rgba(0, 0, 0, 0.16);
  display: flex;
  flex-direction: column;
}

.chat-header {
  height: 112rpx;
  padding: 0 28rpx;
  border-bottom: 2rpx solid #ebeef5;
  background: #f7f8fa;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.header-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #409eff;
}

.chat-title {
  font-size: 30rpx;
  color: #1f2d3d;
  font-weight: 700;
}

.close-icon {
  font-size: 40rpx;
  color: #909399;
}

.chat-body {
  flex: 1;
  min-height: 0;
  padding: 24rpx;
  background: #fdfdfd;
}

.msg-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.msg-left {
  justify-content: flex-start;
}

.msg-right {
  justify-content: flex-end;
}

.avatar {
  min-width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.bg-blue {
  background: #409eff;
}

.bg-orange {
  background: #e6a23c;
}

.msg-bubble {
  max-width: 430rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.assistant-bubble {
  background: #f4f4f5;
  color: #303133;
  border-top-left-radius: 6rpx;
}

.user-bubble {
  background: #409eff;
  color: #ffffff;
  border-top-right-radius: 6rpx;
}

.quick-tips {
  padding: 16rpx 24rpx;
  border-top: 2rpx solid #f0f2f5;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tip-tag {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  border: 2rpx solid #d9ecff;
  color: #409eff;
  background: #f8fcff;
  font-size: 24rpx;
}

.evidence-wrap {
  border-top: 2rpx dashed #f0f2f5;
}

.evidence-tag {
  border-color: #f8d8b4;
  color: #d17c00;
  background: #fff8ee;
}

.chat-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 24rpx 24rpx;
  border-top: 2rpx solid #ebeef5;
  background: #ffffff;
}

.chat-input {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  border: 2rpx solid #dcdfe6;
  padding: 0 24rpx;
  font-size: 26rpx;
  background: #ffffff;
}

.send-btn {
  min-width: 120rpx;
  height: 76rpx;
  border-radius: 38rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  background: linear-gradient(135deg, #409eff, #66b1ff);
}

.send-btn.disabled {
  background: #c0c4cc;
}

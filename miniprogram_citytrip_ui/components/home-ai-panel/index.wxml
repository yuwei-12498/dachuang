<view class="home-ai-panel">
  <view class="panel-header">
    <view class="ai-avatar">AI</view>
    <view class="ai-title-wrap">
      <text class="panel-title">Trip Copilot</text>
      <text class="panel-subtitle">{{user ? "Tell me your preference and I will optimize your route" : "Login to unlock personalized route suggestions"}}</text>
    </view>
  </view>

  <scroll-view class="panel-body" scroll-y="true">
    <view class="msg-list">
      <block wx:for="{{messages}}" wx:key="index">
        <view class="msg-item {{item.role === 'user' ? 'msg-user' : 'msg-ai'}}">
          <view class="bubble">{{item.content}}</view>
        </view>
      </block>
      <view wx:if="{{loading}}" class="msg-item msg-ai">
        <view class="bubble">Thinking...</view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{currentTips.length > 0}}" class="panel-quick-tips">
    <text class="tips-title">Try these:</text>
    <view class="tips-container">
      <text
        wx:for="{{currentTips}}"
        wx:key="index"
        class="tip-tag"
        data-tip="{{item}}"
        bindtap="sendByTip"
      >{{item}}</text>
    </view>
  </view>

  <view wx:if="{{currentEvidence.length > 0}}" class="panel-quick-tips evidence-block">
    <text class="tips-title">Evidence:</text>
    <view class="tips-container">
      <text
        wx:for="{{currentEvidence}}"
        wx:key="index"
        class="tip-tag evidence-tag"
      >{{item}}</text>
    </view>
  </view>

  <view wx:if="{{user}}" class="panel-footer">
    <input
      class="chat-input"
      placeholder="Example: Best photo stop in Kuanzhai Alley?"
      value="{{inputVal}}"
      bindinput="onInput"
      bindconfirm="handleSend"
      confirm-type="send"
    />
    <view class="send-btn {{(!inputVal || loading) ? 'disabled' : ''}}" bindtap="handleSend">Send</view>
  </view>

  <view wx:else class="panel-footer login-footer">
    <text class="login-copy">Login to ask AI for stop ideas, route suggestions, and transport reminders.</text>
    <view class="login-btn" bindtap="goLogin">Login</view>
  </view>
</view>
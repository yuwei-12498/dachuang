page {
  min-height: 100%;
  background: #f7f8fa;
  color: #303133;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.page-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(64, 158, 255, 0.12), transparent 28%),
    linear-gradient(180deg, #f6f9fe 0%, #f7f8fa 100%);
}

.card {
  border-radius: 48rpx;
  border: 2rpx solid rgba(223, 232, 244, 0.95);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(31, 45, 61, 0.06);
}

.pill-button {
  min-height: 84rpx;
  padding: 0 36rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(214, 226, 242, 0.95);
  background: rgba(255, 255, 255, 0.95);
  color: #315170;
  font-size: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.pill-button.primary {
  border-color: #409eff;
  color: #ffffff;
  background: linear-gradient(135deg, #409eff, #66b1ff);
}

.eyebrow {
  margin: 0 0 12rpx;
  color: #2d79c7;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
}
